{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"]
    },
    "target": "ES2017"
  },
  "include": ["src/index.ts", "src/components/**/*", "src/hooks/**/*", "src/lib/**/*"],
  "exclude": [
    "node_modules",
    "src/app",
    "src/stories",
    "src/test",
    "**/*.stories.*",
    "**/*.test.*",
    "**/*.spec.*"
  ]
}
